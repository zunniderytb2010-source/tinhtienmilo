# Copy file này thành .env rồi điền giá trị thật. KHÔNG commit file .env.
# Trên Render thì điền các giá trị này vào tab Environment thay cho file .env.

# Token bot Discord (bắt buộc)
DISCORD_TOKEN=

# Chuỗi kết nối Postgres từ Neon hoặc Supabase (bắt buộc)
# Dạng: postgresql://user:pass@host/dbname?sslmode=require
DATABASE_URL=

# ID kênh mà bot YouTube đăng link video (bắt buộc)
VIDEO_CHANNEL_ID=

# ID kênh gửi báo cáo (mặc định = VIDEO_CHANNEL_ID)
REPORT_CHANNEL_ID=

# ID con bot/webhook YouTube đăng link (TÙY CHỌN).
# Để trống thì bot tính mọi link YouTube do bot/webhook đăng trong kênh.
YOUTUBE_BOT_ID=

# ID người nhận báo cáo, sẽ được tag (bắt buộc)
TSZ_USER_ID=

# Tên nhân viên
WORKER_NAME=milo

# Giá mỗi video (đồng)
PRICE_PER_VIDEO=113000

# Chu kỳ bắt đầu tính, dạng YYYY-MM
START_CYCLE_KEY=2026-07

# Múi giờ
TIMEZONE=Asia/Ho_Chi_Minh

# Giờ:phút gửi báo cáo tự động (ngày 9 hàng tháng)
REPORT_HOUR=9
REPORT_MINUTE=0

# Ký tự gọi lệnh
COMMAND_PREFIX=!

# KHÔNG cần set PORT khi chạy trên Render (Render tự set).
# Chỉ set khi chạy máy local nếu muốn đổi cổng web keep-alive.
# PORT=10000
