# Copy file này thành .env rồi điền giá trị thật. KHÔNG commit file .env.

# Token bot Discord (bắt buộc)
DISCORD_TOKEN=

# ID kênh mà bot YouTube đăng link video (bắt buộc)
VIDEO_CHANNEL_ID=

# ID kênh gửi báo cáo (mặc định = VIDEO_CHANNEL_ID)
REPORT_CHANNEL_ID=

# ID của con bot YouTube đăng link (bắt buộc)
YOUTUBE_BOT_ID=

# ID người nhận báo cáo, sẽ được tag (bắt buộc)
TSZ_USER_ID=

# Tên nhân viên
WORKER_NAME=milo

# Giá mỗi video (đồng)
PRICE_PER_VIDEO=113000

# Chu kỳ bắt đầu tính, dạng YYYY-MM
START_CYCLE_KEY=2026-07

# Tên file lưu dữ liệu
DATA_FILE=milo_pay.json

# Múi giờ
TIMEZONE=Asia/Ho_Chi_Minh

# Giờ:phút gửi báo cáo tự động (ngày 9 hàng tháng)
REPORT_HOUR=9
REPORT_MINUTE=0

# Ký tự gọi lệnh
COMMAND_PREFIX=!
